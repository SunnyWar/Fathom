//! Example showing how to use the helper API

#[cfg(feature = "helper-api")]
use rfathom::helper::*;
use rfathom::Color;

#[cfg(feature = "helper-api")]
fn main() {
    println!("RFathom Helper API Examples\n");

    // Example 1: Pop count (count set bits)
    let bitboard = 0xFF00_0000_0000_00FF; // 16 bits set
    println!("Bitboard: {:064b}", bitboard);
    println!("Pop count: {}\n", pop_count(bitboard));

    // Example 2: LSB (least significant bit)
    let bb = 0x0000_0000_0000_0100; // bit 8 set
    println!("Bitboard: {:064b}", bb);
    println!("LSB position: {}\n", lsb(bb));

    // Example 3: Pop LSB
    let mut bb = 0x0000_0000_0000_1111; // bits 0-3 set
    println!("Original: {:064b}", bb);
    let (new_bb, square) = pop_lsb(bb);
    println!("After pop_lsb: {:064b}", new_bb);
    println!("Popped square: {}\n", square);

    // Example 4: King attacks
    let square = 27; // e4 in 0-63 notation
    let attacks = king_attacks(square);
    println!("King attacks from e4:");
    print_bitboard(attacks);

    // Example 5: Knight attacks
    let attacks = knight_attacks(square);
    println!("\nKnight attacks from e4:");
    print_bitboard(attacks);

    // Example 6: Pawn attacks
    let white_attacks = pawn_attacks(square, Color::White);
    println!("\nWhite pawn attacks from e4:");
    print_bitboard(white_attacks);

    let black_attacks = pawn_attacks(square, Color::Black);
    println!("\nBlack pawn attacks from e4:");
    print_bitboard(black_attacks);

    // Example 7: Sliding piece attacks
    let occupancy = 0x0000_0010_0810_0000; // Some pieces on the board
    println!("\nOccupancy:");
    print_bitboard(occupancy);

    let rook_atk = rook_attacks(square, occupancy);
    println!("\nRook attacks from e4:");
    print_bitboard(rook_atk);

    let bishop_atk = bishop_attacks(square, occupancy);
    println!("\nBishop attacks from e4:");
    print_bitboard(bishop_atk);

    let queen_atk = queen_attacks(square, occupancy);
    println!("\nQueen attacks from e4:");
    print_bitboard(queen_atk);
}

#[cfg(feature = "helper-api")]
fn print_bitboard(bb: u64) {
    println!("  +---+---+---+---+---+---+---+---+");
    for rank in (0..8).rev() {
        print!("{} |", rank + 1);
        for file in 0..8 {
            let square = rank * 8 + file;
            let occupied = (bb >> square) & 1 == 1;
            print!(" {} |", if occupied { "X" } else { " " });
        }
        println!("\n  +---+---+---+---+---+---+---+---+");
    }
    println!("    a   b   c   d   e   f   g   h");
}

#[cfg(not(feature = "helper-api"))]
fn main() {
    println!("This example requires the 'helper-api' feature.");
    println!("Run with: cargo run --example helper_api --features helper-api");
}
